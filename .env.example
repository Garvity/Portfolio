# Optional — contact form email delivery via EmailJS (https://www.emailjs.com)
# Without these, the contact form falls back to opening the visitor's mail client.
# Template HTML for both templates lives in docs/ — paste into the EmailJS code editor.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Optional — second template (docs/emailjs-autoreply-template.html) that sends a
# confirmation email to the visitor. Leave empty to skip auto-replies.
VITE_EMAILJS_AUTOREPLY_TEMPLATE_ID=
